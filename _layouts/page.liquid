---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
    {% if page.collection == 'projects' %}
      <p class="project-back-link mb-2">
        <a href="{{ '/projects/' | relative_url }}" aria-label="Back to Projects">&larr; Back to Projects</a>
      </p>
    {% endif %}
  </header>

  {% assign project_hero_img = page.hero_img | default: page.img %}
  {% if page.collection == 'projects' and project_hero_img %}
    <div class="project-hero">
      <a
        href="{{ project_hero_img | relative_url }}"
        class="research-zoomable"
        style="display: block; cursor: zoom-in; text-decoration: none;"
        data-image-zoomable
        data-image-title="{{ page.title | escape }}"
        aria-label="Open project figure"
      >
        {% include figure.liquid loading="eager" path=project_hero_img alt=page.title class="project-hero__image" %}
      </a>
    </div>
  {% endif %}

  {% if page.collection == 'projects' and page.figure_captions %}
    <div class="project-figure-captions">
      <p class="project-figure-captions__title">Figure captions:</p>
      <ul>
        {% for caption in page.figure_captions %}
          <li>{{ caption }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if page.collection == 'projects' %}
    <script defer src="{{ '/assets/js/research-image-modal.js' | relative_url | bust_file_cache }}"></script>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
